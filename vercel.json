{
  "version": 2,
  "builds": [
    {
      "src": "Backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/rms_front/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist" 
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/Backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/Frontend/rms_front/dist/$1"
    }
  ]
}